# Dependencies (Railway/Render run their own `npm install`)
node_modules/

# Secrets — never commit. .env.example IS committed as the template.
.env
.env.local
.env.*.local

# User-uploaded media (served from object storage / CDN in production)
public/uploads/

# Logs & OS cruft
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# Claude Code harness scheduling lock (per-machine, not shareable)
.claude/scheduled_tasks.lock
backups/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
