{
  "name": "4kautos",
  "version": "2.0.0",
  "description": "4Kautos — Premium Preowned Car Marketplace",
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "backfill:images": "node backend/scripts/backfill-responsive-images.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@sentry/node": "^10.64.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.11.4",
    "nodemailer": "^9.0.1",
    "path-to-regexp": "^8.4.2",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "transform": {},
    "setupFiles": [
      "./backend/tests/setup.js"
    ],
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
