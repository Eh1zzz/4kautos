# Server
PORT=3000
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# MySQL — create the databases first:  CREATE DATABASE 4kautos;  CREATE DATABASE 4kautos_test;
DATABASE_URL=mysql://root:password@localhost:3306/4kautos
DATABASE_URL_TEST=mysql://root:password@localhost:3306/4kautos_test

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Anthropic (optional — chatbot uses this key server-side)
ANTHROPIC_API_KEY=sk-ant-...
