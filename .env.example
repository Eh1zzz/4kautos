NODE_ENV=production

TRUST_PROXY=1

DATABASE_URL=${{MySQL.MYSQL_URL}}

JWT_SECRET=PASTE_YOUR_RANDOM_STRING_HERE

ALLOWED_ORIGINS=https://PASTE_YOUR_RAILWAY_DOMAIN_HERE

# ── Scaling knobs (all OPTIONAL — sensible defaults; set when you scale out) ──
# DB pool: keep  (replicas × DB_POOL_SIZE)  under MySQL max_connections.
# DB_POOL_SIZE=10
# DB_QUEUE_LIMIT=0
# DB_SSL=true                      # if your managed MySQL requires TLS
# Free-text search backend: 'like' (default substring) | 'fulltext' (MATCH..AGAINST, indexed) | unset = auto (fulltext when all query words are ≥3 chars).
# SEARCH_MODE=
# Redis: when set, rate-limit state + Socket.IO broadcasts are shared across
# replicas (required to run more than one instance). Unset = single-node in-memory.
# REDIS_URL=${{Redis.REDIS_URL}}