# ─────────────────────────────────────────────────────────────
#  4Kautos — environment variables
#  Copy to .env and fill in. Only DATABASE_URL + JWT_SECRET are required to boot.
# ─────────────────────────────────────────────────────────────

# ── Server ──
PORT=3000
# Set NODE_ENV=production on your host (Railway/Render). It enforces a strong
# JWT_SECRET and the strict CORS allow-list below.
# NODE_ENV=production

# Proxy hops to trust for the real client IP (used by the rate-limiter).
# Local dev: 0. Direct Railway/Render: 1. With Cloudflare in front: 2.
TRUST_PROXY=0

# Comma-separated browser origins allowed in production (your frontend URLs).
# e.g. https://4kautos.com,https://www.4kautos.com,https://4kautos.pages.dev
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ── Database (MySQL) ──
# Create the DBs first:  CREATE DATABASE 4kautos;  CREATE DATABASE 4kautos_test;
# On Railway, paste the MySQL plugin's connection string here.
DATABASE_URL=mysql://root:password@localhost:3306/4kautos
DATABASE_URL_TEST=mysql://root:password@localhost:3306/4kautos_test

# ── Auth ──
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# ── Anthropic (optional — AutoBot uses this server-side) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (optional) ──
# Priority: Resend (if RESEND_API_KEY set) → Gmail SMTP → silently skipped.
# Resend (recommended for production deliverability): https://resend.com
RESEND_API_KEY=
# "From" address. Until you verify a domain in Resend you can use its shared
# sender onboarding@resend.dev. After verifying: 4Kautos <noreply@yourdomain.com>
MAIL_FROM=
# Gmail fallback — use a Google App Password (Account → Security → 2-Step → App
# passwords), NOT your normal password. Leave blank if using Resend.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Object storage (optional — for car photos) ──
# Unset = images are written to local disk (public/uploads), fine for dev.
# Set these to push to Cloudflare R2 (recommended: zero egress fees), AWS S3, or
# Backblaze B2. ASSET_BASE_URL is REQUIRED when S3_BUCKET is set.
S3_BUCKET=
# Cloudflare R2 → "auto".  AWS → e.g. us-east-1.
S3_REGION=auto
# R2/B2 endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com  (omit for AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Some providers (e.g. B2) need path-style URLs. R2/S3: leave false.
S3_FORCE_PATH_STYLE=false
# Public domain that serves the bucket (R2 public/custom domain or your CDN), e.g.
# https://cdn.4kautos.com  — returned image URLs are ASSET_BASE_URL/<hash>.webp
ASSET_BASE_URL=
